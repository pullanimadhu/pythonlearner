# --- LLM (Drytis OpenAI-compatible gateway) ---
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://llm.drytis.ai
MODEL_NAME=z-ai/glm-5

# --- Embeddings (local sentence-transformers) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Retrieval ---
RETRIEVAL_K=10
FINAL_K=5

# --- Paths ---
FAISS_INDEX_PATH=/workspace/data/faiss_index
DATA_DIR=/workspace/data
QUESTIONS_CSV=/workspace/sampleQuestion.csv
ANSWERS_CSV=/workspace/sampleAnswer.csv
TAGS_CSV=/workspace/Tags.csv

# --- App ---
APP_ENV=development
APP_DEBUG=true
